{
  "name": "lms-ojt",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "infra:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.dev.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.dev.yml logs -f",
    "db:generate": "pnpm --filter @lms/db db:generate",
    "db:migrate": "pnpm --filter @lms/db db:migrate",
    "db:seed:super-admin": "pnpm --filter @lms/db db:seed:super-admin"
  },
  "devDependencies": {
    "prettier": "^3.7.1",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  }
}
